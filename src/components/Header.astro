---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
---

<header class="header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-icon">🌱</span>
        <span class="logo-text">揉光入野</span>
      </a>
      <div class="nav-links">
        <a href="/">首页</a>
        <a href="/blog">文章</a>
        <a href="/tags">标签</a>
        <a href="/about">关于</a>
      </div>
      <div class="nav-actions">
        <Search />
        <ThemeToggle />
        <a href="/rss.xml" class="rss-link" title="RSS 订阅" aria-label="RSS 订阅">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 60px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover {
    color: var(--color-primary);
  }

  .logo-icon {
    font-size: 1.3rem;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    flex: 1;
  }

  .nav-links a {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .rss-link {
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .rss-link:hover {
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>
