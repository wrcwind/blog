---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags: string[];
  readingTime: number;
}

const { title, description, pubDate, tags, readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="post-wrapper">
    <div class="post">
      <div class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="separator">·</span>
          <span>{readingTime} 分钟阅读</span>
        </div>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        )}
      </div>
      <div class="post-body">
        <div class="toc-wrapper" id="tocWrapper">
          <div class="toc">
            <div class="toc-title">目录</div>
            <div class="toc-content" id="tocContent"></div>
          </div>
        </div>
        <div class="post-content">
          <slot />
        </div>
      </div>
      <Giscus />
    </div>
  </article>
</BaseLayout>

<script is:inline>
  function buildTOC() {
    var content = document.querySelector('.post-content');
    var tocContent = document.getElementById('tocContent');
    var tocWrapper = document.getElementById('tocWrapper');
    if (!content || !tocContent || !tocWrapper) return;

    var headings = content.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      tocWrapper.style.display = 'none';
      return;
    }

    var fragment = document.createDocumentFragment();
    headings.forEach(function(h, i) {
      if (!h.id) h.id = 'heading-' + i;
      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent;
      a.className = h.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
      a.addEventListener('click', function(e) {
        e.preventDefault();
        h.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      fragment.appendChild(a);
    });
    tocContent.appendChild(fragment);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', buildTOC);
  } else {
    buildTOC();
  }
</script>

<style>
  .post-wrapper {
    max-width: 100%;
  }

  .post {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .separator {
    color: var(--color-border);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--color-bg-secondary);
    border-radius: 9999px;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    transition: all 0.2s;
  }

  .tag:hover {
    background: var(--color-primary);
    color: white;
  }

  .post-body {
    position: relative;
  }

  .toc-wrapper {
    position: absolute;
    left: calc(100% + 2rem);
    top: 0;
    width: 200px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .toc {
    position: sticky;
    top: 80px;
    padding: 1rem;
    border-left: 2px solid var(--color-border);
    font-size: 0.85rem;
  }

  .toc-title {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .toc-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .toc-content a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
    line-height: 1.5;
  }

  .toc-content a:hover {
    color: var(--color-primary);
  }

  .toc-h3 {
    padding-left: 1rem;
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    margin: 2.5rem 0 1rem;
    font-weight: 600;
  }

  .post-content :global(h3) {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
    font-weight: 600;
  }

  .post-content :global(p) {
    margin: 1.25rem 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin: 0.5rem 0;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post-content :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: 0.6rem 0.8rem;
    text-align: left;
    border: 1px solid var(--color-border);
  }

  .post-content :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 600;
  }

  .post-content :global(tr:nth-child(even)) {
    background: var(--color-bg-secondary);
  }

  @media (max-width: 1080px) {
    .toc-wrapper {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .post {
      padding: 2rem 1rem 4rem;
    }

    .post-title {
      font-size: 1.75rem;
    }
  }
</style>
