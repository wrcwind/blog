---
import PostCard from './PostCard.astro';

interface Post {
  slug: string;
  data: {
    title: string;
    pubDate: Date;
    tags: string[];
    description?: string;
    cover?: string;
  };
  readingTime: number;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="post-list">
  {posts.map(post => (
    <PostCard
      title={post.data.title}
      description={post.data.description}
      pubDate={post.data.pubDate}
      tags={post.data.tags}
      slug={post.slug}
      readingTime={post.readingTime}
      cover={post.data.cover}
    />
  ))}
</div>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
