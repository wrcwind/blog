---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../../utils/index.ts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const readingTime = calculateReadingTime(post.body ?? '');

// 上一篇 / 下一篇
const allPosts = (await getCollection('blog'))
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
const currentIndex = allPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  readingTime={readingTime}
>
  <Content />
</PostLayout>

{(prevPost || nextPost) && (
  <nav class="post-nav">
    <div class="container">
      {prevPost && (
        <a href={`/blog/${prevPost.slug}`} class="post-nav-item prev">
          <span class="nav-label">← 上一篇</span>
          <span class="nav-title">{prevPost.data.title}</span>
        </a>
      )}
      {nextPost && (
        <a href={`/blog/${nextPost.slug}`} class="post-nav-item next">
          <span class="nav-label">下一篇 →</span>
          <span class="nav-title">{nextPost.data.title}</span>
        </a>
      )}
    </div>
  </nav>
)}

<style>
  .post-nav {
    border-top: 1px solid var(--color-border);
    margin-top: 0;
  }

  .post-nav .container {
    max-width: var(--content-width);
    display: flex;
    gap: 1.5rem;
    padding: 2rem 1.5rem;
    margin: 0 auto;
  }

  .post-nav-item {
    flex: 1;
    text-decoration: none;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .post-nav-item:hover {
    border-color: var(--color-primary);
  }

  .post-nav-item.next {
    text-align: right;
  }

  .nav-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .post-nav-item:hover .nav-label {
    color: var(--color-primary);
  }

  .nav-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .post-nav .container {
      flex-direction: column;
      padding: 1.5rem 1rem;
    }

    .post-nav-item.next {
      text-align: left;
    }
  }
</style>
