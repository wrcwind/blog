---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../utils/index.ts';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(post => ({
    ...post,
    readingTime: calculateReadingTime(post.body ?? '')
  }));
---

<BaseLayout title="揉光入野 - AI思考 · 生活重建 · 自然记录">
  <div class="home">
    <!-- About Section -->
    <section class="about">
      <div class="container">
        <div class="about-content">
          <img src="/avatar.jpg" alt="揉光入野" class="about-avatar" />
          <div class="about-text">
            <h1 class="about-title">🌱 揉光入野</h1>
            <p class="about-description">
              写了8年Java的技术人。从北京到杭州，正在重建与世界的联系。这里分享AI技术思考、生活重建和自然徒步的真实记录。
            </p>
            <div class="about-links">
              <a href="/about">了解更多</a>
              <a href="/rss.xml">RSS 订阅</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Posts Section -->
    <section class="posts">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">最新文章</h2>
          <a href="/blog" class="view-all">查看全部 →</a>
        </div>
        <div class="post-list">
          {posts.slice(0, 5).map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.slug}
              readingTime={post.readingTime}
            />
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    padding-bottom: 4rem;
  }

  .about {
    padding: 4rem 0;
    background: var(--color-bg-secondary);
    margin-bottom: 3rem;
  }

  .about-content {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .about-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .about-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .about-description {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 600px;
    font-size: 1.05rem;
  }

  .about-links {
    display: flex;
    gap: 1rem;
  }

  .about-links a {
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  .about-links a:first-child {
    background: var(--color-primary);
    color: white;
  }

  .about-links a:first-child:hover {
    background: var(--color-primary-dark);
    color: white;
  }

  .about-links a:last-child {
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .about-links a:last-child:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .view-all {
    color: var(--color-primary);
    font-size: 0.95rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .about-content {
      flex-direction: column;
      text-align: center;
    }

    .about-avatar {
      width: 80px;
      height: 80px;
    }

    .about-description {
      margin-left: auto;
      margin-right: auto;
    }

    .about-links {
      justify-content: center;
    }
  }
</style>
